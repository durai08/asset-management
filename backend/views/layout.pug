doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{title} | Asset Management
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet" href="https://cdn.datatables.net/1.13.5/css/dataTables.bootstrap5.min.css")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(rel="stylesheet" href="/css/style.css")

  body
 
    .sidebar-overlay#sidebarOverlay

    .app-container
 
      aside.sidebar#sidebar
        .sidebar-header
          a.sidebar-brand(href="/")
            i.fa-solid.fa-boxes-stacked
            span Asset Manager

        ul.sidebar-menu
          li.sidebar-section Workspace
          li.sidebar-item
            a.sidebar-link(href="/" class=(activePage === 'dashboard' ? 'active' : ''))
              i.fa-solid.fa-chart-pie
              span Dashboard
          li.sidebar-item
            a.sidebar-link(href="/assets" class=(activePage === 'assets' ? 'active' : ''))
              i.fa-solid.fa-box
              span Assets
          li.sidebar-item
            a.sidebar-link(href="/categories" class=(activePage === 'categories' ? 'active' : ''))
              i.fa-solid.fa-tags
              span Categories
          li.sidebar-item
            a.sidebar-link(href="/employees" class=(activePage === 'employees' ? 'active' : ''))
              i.fa-solid.fa-users
              span Employees
          li.sidebar-item
            a.sidebar-link(href="/stock" class=(activePage === 'stock' ? 'active' : ''))
              i.fa-solid.fa-warehouse
              span Stock View

          li.sidebar-section(style="margin-top:8px") Transactions
          li.sidebar-item
            a.sidebar-link(href="/issues" class=(activePage === 'issues' ? 'active' : ''))
              i.fa-solid.fa-arrow-right-from-bracket
              span Issue Asset
          li.sidebar-item
            a.sidebar-link(href="/returns" class=(activePage === 'returns' ? 'active' : ''))
              i.fa-solid.fa-arrow-rotate-left
              span Return Asset
          li.sidebar-item
            a.sidebar-link(href="/history" class=(activePage === 'history' ? 'active' : ''))
              i.fa-solid.fa-clock-rotate-left
              span History Logs

    
      .main-wrapper
       
        header.topbar
          .topbar-left
            button.btn-hamburger#hamburgerBtn(type="button" aria-label="Toggle sidebar")
              i.fa-solid.fa-bars
            span.topbar-title #{title}

          .topbar-right
            .status-pill
              .status-dot
              span System Active

        main.content-body
          block content


    script(src="https://code.jquery.com/jquery-3.6.0.min.js")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script(src="https://cdn.datatables.net/1.13.5/js/jquery.dataTables.min.js")
    script(src="https://cdn.datatables.net/1.13.5/js/dataTables.bootstrap5.min.js")

   
    script.
      (function() {
        var sidebar  = document.getElementById('sidebar');
        var overlay  = document.getElementById('sidebarOverlay');
        var hamburger = document.getElementById('hamburgerBtn');

        function openSidebar() {
          sidebar.classList.add('open');
          overlay.classList.add('show');
          document.body.style.overflow = 'hidden';
        }
        function closeSidebar() {
          sidebar.classList.remove('open');
          overlay.classList.remove('show');
          document.body.style.overflow = '';
        }

        hamburger.addEventListener('click', function() {
          if (sidebar.classList.contains('open')) { closeSidebar(); }
          else { openSidebar(); }
        });
        overlay.addEventListener('click', closeSidebar);

        document.querySelectorAll('.sidebar-link').forEach(function(link) {
          link.addEventListener('click', function() {
            if (window.innerWidth < 992) closeSidebar();
          });
        });
      })();

    block scripts
